# このファイルを config.env にコピーして編集してください
# cp config.example.env config.env

# --- 中継ホスト（常時起動・wakeonlan を実行するマシン）---
# Tailscale MagicDNS 名または Tailscale IP（例: nas または 100.x.x.x）
WOL_RELAY_HOST="nas"

# SSH ユーザー名（中継ホストにログインするアカウント）
SSH_USER="mitac"

# SSH 認証方式: password（パスワード）または key（鍵）
SSH_AUTH="password"

# パスワード認証時のパスワード（省略時は実行時に GUI で入力）
# ワンクリック運用向け。平文保存になるため取り扱いに注意
# SSH_PASSWORD="your-password"

# 中継ホスト上の wake-relay.sh のパス（install.sh 実行後のデフォルト）
RELAY_SCRIPT_PATH="~/wol/wake-relay.sh"

# --- 起動対象 PC ---
# 起動したい PC の MAC アドレス（コロン区切り）
WOL_TARGET_MAC="AA:BB:CC:DD:EE:FF"

# 起動確認用: 対象 PC の Tailscale ホスト名または IP
WOL_TARGET_HOST="desktop-pc"

# ブロードキャストアドレス（省略時は中継ホストのデフォルトサブネット）
# 対象 PC と中継ホストが同じ LAN にいる場合のみ必要なことがあります
# WOL_BROADCAST="192.168.1.255"

# --- 起動確認 ---
# WOL 送信後、対象 PC が応答するまで待つ最大秒数
WAKE_TIMEOUT_SEC=120

# ping の間隔（秒）
PING_INTERVAL_SEC=5

# --- 通知（起動しなかった場合）---
# Linux デスクトップ通知（notify-send）を使う: 1=有効, 0=無効
USE_DESKTOP_NOTIFY=1

# ntfy でスマホ等に通知する場合（任意）
# 例: https://ntfy.sh/your-topic または ntfy.sh/your-topic
# NTFY_TOPIC=""
